    print(f"  SAMPLE {i} — {sample['genre']}  |  {sample['description']}")
    print(f"{'─'*72}")
    print(f"  [Step 2] Input received : '{result['query']}'")
    print(f"           Resolved to    : '{result['resolved_title']}'  ({result['resolve_method']})")
    print(f"  [Step 3] Model ran in   : {result['elapsed_ms']} ms")
    print(f"  [Step 4] Enriched {result['total_results']} recommendations\n")

    print(f"  {'Rank':<5} {'Title':<35} {'Score':>6}  {'Confidence':>10}  {'Stars':<10}  Priority")
    print(f"  {'─'*4}  {'─'*34}  {'─'*6}  {'─'*10}  {'─'*9}  {'─'*20}")
    for card in result["results"]:
        print(f"  {card['rank']:<5} {card['title'][:34]:<35} "
              f"{card['score']:>6.4f}  {card['confidence']:>10}  "
              f"{card['stars']:<10}  {card['watch_priority']}")

