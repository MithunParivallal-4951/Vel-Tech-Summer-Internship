SEP  = "=" * 72
SEP2 = "-" * 72

def print_summary_table(all_results: list):
    """Print a compact summary table of all 5 tests."""
    print(f"\n{'SUMMARY TABLE':^72}")
    print(SEP)
    print(f"{'#':<3} {'Input Title':<22} {'Top Recommendation':<28} {'Match%':>7}  {'Stars'}")
    print(SEP2)
    for i, res in enumerate(all_results, 1):
        if res["status"] == "success" and res["results"]:
            top = res["results"][0]
            print(f"{i:<3} {res['query']:<22} {top['title'][:27]:<28} "
                  f"{top['confidence']:>7}  {top['stars']}")
        else:
            print(f"{i:<3} {res['query']:<22} {'ERROR':<28}")
    print(SEP)

