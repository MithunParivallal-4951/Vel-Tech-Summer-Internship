import math
import pathlib
import pickle
import time

# ── Patch so Windows-saved model loads on Linux / Mac ─────────────────────────
pathlib.WindowsPath = pathlib.PurePosixPath

MODEL_PATH = "movie_recommender.pkl"

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 1 — Load model (done once, reused for all 5 samples)
# ══════════════════════════════════════════════════════════════════════════════

def load_model(path: str):
    print(f"[Step 1] Loading model from '{path}' ...")
    with open(path, "rb") as f:
        model = pickle.load(f)
    print(f"         ✔  Loaded — {len(model.movies):,} movies indexed")
    print(f"         ✔  Feature columns: {model.used_text_columns}")
    return model

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 2 — Preprocess input (title normalisation + existence check)
# ══════════════════════════════════════════════════════════════════════════════

def preprocess_input(raw_title: str, model) -> str:
    """
    Normalise the raw user input and resolve it to an exact title
    in the dataset.  If no exact match, auto-selects the closest
    search result (simulates a search-as-you-type UX).
    """
    normalised = raw_title.strip().lower()
    exact = any(m["normalized_title"] == normalised for m in model.movies)

    if exact:
        # Return the correctly-cased title from the dataset
        resolved = next(
            m["title"] for m in model.movies if m["normalized_title"] == normalised
        )
        return resolved, "exact match"
    else:
        suggestions = model.search_titles(raw_title, limit=3)
        if suggestions:
            return suggestions[0], f"auto-resolved from search → '{suggestions[0]}'"
        raise ValueError(f"Movie '{raw_title}' not found and no close matches.")

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 3 — Model prediction (cosine similarity retrieval)
# ══════════════════════════════════════════════════════════════════════════════

def predict(title: str, model, top_k: int = 5) -> list:
    """
    Run the recommender model and return raw recommendation dicts.
    Each dict: { 'title': str, 'similarity_score': float }
    """
    return model.recommend(title, limit=top_k)

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 4 — Output enrichment (convert raw score to human-readable card)
# ══════════════════════════════════════════════════════════════════════════════

def enrich_recommendation(rank: int, rec: dict) -> dict:
    """
    Converts a raw recommendation dict into a rich, human-readable card.

    Input  : { 'title': '...', 'similarity_score': 0.5329 }
    Output : full enriched dict with label, stars, priority, tag
    """
    score = rec["similarity_score"]

    if score >= 0.85:
        label    = "Excellent match"
        priority = "Watch immediately"
        stars    = "★★★★★"
        tag      = "TOP PICK"
    elif score >= 0.70:
        label    = "Strong match"
        priority = "Highly recommended"
        stars    = "★★★★☆"
        tag      = "GREAT"
    elif score >= 0.50:
        label    = "Good match"
        priority = "Worth watching"
        stars    = "★★★☆☆"
        tag      = "GOOD"
    elif score >= 0.30:
        label    = "Moderate match"
        priority = "If you have time"
        stars    = "★★☆☆☆"
        tag      = "OK"
    else:
        label    = "Loose match"
        priority = "Exploratory"
        stars    = "★☆☆☆☆"
        tag      = "WEAK"

    return {
        "rank":          rank,
        "title":         rec["title"],
        "score":         score,
        "confidence":    f"{score * 100:.1f}%",
        "match_label":   label,
        "watch_priority": priority,
        "stars":         stars,
        "tag":           tag,
    }

# ══════════════════════════════════════════════════════════════════════════════
#  STEP 5 — Full pipeline runner
# ══════════════════════════════════════════════════════════════════════════════

def run_full_prediction(raw_input: str, model, top_k: int = 5) -> dict:
    """
    Full end-to-end pipeline:
      raw user input → preprocess → predict → enrich → return result dict

    Parameters
    ----------
    raw_input : str   — movie title exactly as typed by a user
    model     : MovieRecommender — loaded model
    top_k     : int   — number of recommendations to return

    Returns
    -------
    dict with keys:
        status, query, resolved_title, resolve_method,
        total_results, results (list of enriched cards)
    """
    t0 = time.perf_counter()

    # Step 2 — preprocess
    resolved_title, resolve_method = preprocess_input(raw_input, model)

    # Step 3 — predict
    raw_recs = predict(resolved_title, model, top_k)

    # Step 4 — enrich each result
    enriched = [enrich_recommendation(r + 1, rec) for r, rec in enumerate(raw_recs)]

    elapsed = time.perf_counter() - t0

    return {
        "status":         "success",
        "query":          raw_input,
        "resolved_title": resolved_title,
        "resolve_method": resolve_method,
        "total_results":  len(enriched),
        "elapsed_ms":     round(elapsed * 1000, 1),
        "results":        enriched,
    }

